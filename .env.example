# URL pública del sitio (sin barra final). Usada en Open Graph, Twitter Card y canonical vía build + cliente.
# Copiar a .env o .env.production y ajustar al dominio real de despliegue.
VITE_SITE_ORIGIN=https://spiralmstudio.com

# Opcionales para desarrollo local/HMR.
# VITE_DEV_HOST=localhost
# VITE_DEV_PORT=5173
# Deja HMR sin forzar en local normal.
# Solo define estas variables si usas proxy/túnel/HTTPS local y el socket falla:
# VITE_HMR_HOST=localhost
# VITE_HMR_PORT=5173
# VITE_HMR_CLIENT_PORT=5173
# VITE_HMR_PROTOCOL=ws

# --- Build / Vercel (no afectan el bundle del cliente si no llevan prefijo VITE_) ---
# En local, `pnpm build` ejecuta Sharp (optimize:images + logos) y luego Vite.
# En Vercel (`VERCEL=1`) el build OMITE Sharp por defecto para acortar deploy: mismas
# imágenes si ya están commitadas en public/images/optimized y derivados.
# Para forzar regeneración en Vercel (p. ej. tras cambiar JPG fuente): pon en el proyecto Vercel
# RUN_SHARP_OPTIMIZE=1 (una vez o temporalmente).
# Para omitir Sharp también en máquina local:
# SKIP_IMAGE_OPTIMIZE=1

# --- Stripe (Book Now) ---
# Secret key del backend para crear Checkout Sessions y confirmar pagos.
# STRIPE_SECRET_KEY=sk_live_xxx
# Opcional (frontend), útil para futuras integraciones con Stripe Elements.
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Secret de firma del webhook Stripe (endpoint `/api/stripe-webhook`).
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Dominio público del sitio para success/cancel URL de Stripe Checkout.
# Si no defines PUBLIC_SITE_ORIGIN, se usa VITE_SITE_ORIGIN.
# PUBLIC_SITE_ORIGIN=https://spiralmstudio.com
# Límite de requests por ventana para /api/create-checkout-session.
# BOOKING_RATE_LIMIT_MAX=10
# BOOKING_RATE_LIMIT_WINDOW_MS=60000

# --- Cloudflare Turnstile (anti-bot para checkout) ---
# Site key público (frontend). Si está presente, el formulario requiere challenge.
# VITE_TURNSTILE_SITE_KEY=0x4AAAA...
# Secret key privado (backend) para validar token en create-checkout-session.
# En producción, si falta TURNSTILE_SECRET_KEY, el endpoint devuelve error de configuración.
# TURNSTILE_SECRET_KEY=0x4AAAA...

# Orígenes permitidos para las APIs de reserva (CORS / anti-abuso).
# Lista separada por comas. www y sin www se tratan como el mismo host.
# Si solo defines un preview de Vercel aquí, producción (spiralmstudio.com) recibirá 403 Forbidden.
# ALLOWED_ORIGIN=https://spiralmstudio.com,https://www.spiralmstudio.com
# También se aceptan automáticamente PUBLIC_SITE_ORIGIN / VITE_SITE_ORIGIN y spiralmstudio.com.

# --- Auth y header security para checkout ---
# Requiere sesión autenticada vía Supabase (Bearer token en Authorization).
# El backend valida el token contra /auth/v1/user.
# REQUIRE_BOOKING_SUPABASE_AUTH=1
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
#
# Capa adicional (fallback) por header secreto.
# Nota: si el secreto vive en frontend, NO reemplaza autenticación real; úsalo como defensa adicional.
# REQUIRE_CHECKOUT_HEADER_SECRET=1
# CHECKOUT_HEADER_SECRET_NAME=x-checkout-secret
# CHECKOUT_HEADER_SECRET=un-valor-largo-y-aleatorio
# VITE_CHECKOUT_HEADER_SECRET_NAME=x-checkout-secret
# VITE_CHECKOUT_HEADER_SECRET=un-valor-largo-y-aleatorio
#
# Cifrado de contacto en checkout (RSA + AES-GCM). Generar par con:
#   node scripts/generate-checkout-contact-keys.mjs
# VITE_CHECKOUT_CONTACT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# CHECKOUT_CONTACT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Solo desarrollo local (no usar en producción):
# CHECKOUT_ALLOW_PLAINTEXT_CONTACT=1

# --- Resend (emails de confirmación de reserva) ---
# API key de Resend.
# RESEND_API_KEY=re_xxx
# Remitente verificado en Resend (ej: bookings@tu-dominio.com)
# Solo la dirección o formato completo; el nombre visible será RESEND_FROM_NAME (default: Spiral).
# RESEND_FROM_EMAIL=bookings@tu-dominio.com
# RESEND_FROM_NAME=Spiral
# Logo en correos: PNG en /images/email/spiral-logo-white.png (generar con pnpm optimize:logos).
# Se adjunta inline al enviar; fallback URL pública si falta el archivo:
# RESEND_EMAIL_LOGO_URL=https://spiralmstudio.com/images/email/spiral-logo-white.png
# Email del dueño/estudio que recibirá notificaciones.
# STUDIO_NOTIFICATION_EMAIL=owner@tu-dominio.com
