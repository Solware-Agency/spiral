# URL pública del sitio (sin barra final). Usada en Open Graph, Twitter Card y canonical vía build + cliente.
# Copiar a .env o .env.production y ajustar al dominio real de despliegue.
VITE_SITE_ORIGIN=https://spiralmstudio.com

# Opcionales para desarrollo local/HMR.
# VITE_DEV_HOST=localhost
# VITE_DEV_PORT=5173
# Deja HMR sin forzar en local normal.
# Solo define estas variables si usas proxy/túnel/HTTPS local y el socket falla:
# VITE_HMR_HOST=localhost
# VITE_HMR_PORT=5173
# VITE_HMR_CLIENT_PORT=5173
# VITE_HMR_PROTOCOL=ws

# --- Build / Vercel (no afectan el bundle del cliente si no llevan prefijo VITE_) ---
# En local, `pnpm build` ejecuta Sharp (optimize:images + logos) y luego Vite.
# En Vercel (`VERCEL=1`) el build OMITE Sharp por defecto para acortar deploy: mismas
# imágenes si ya están commitadas en public/images/optimized y derivados.
# Para forzar regeneración en Vercel (p. ej. tras cambiar JPG fuente): pon en el proyecto Vercel
# RUN_SHARP_OPTIMIZE=1 (una vez o temporalmente).
# Para omitir Sharp también en máquina local:
# SKIP_IMAGE_OPTIMIZE=1

# --- Stripe (Book Now) ---
# Secret key del backend para crear Checkout Sessions y confirmar pagos.
# STRIPE_SECRET_KEY=sk_live_xxx
# Opcional (frontend), útil para futuras integraciones con Stripe Elements.
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Dominio público del sitio para success/cancel URL de Stripe Checkout.
# Si no defines PUBLIC_SITE_ORIGIN, se usa VITE_SITE_ORIGIN.
# PUBLIC_SITE_ORIGIN=https://spiralmstudio.com

# --- Resend (emails de confirmación de reserva) ---
# API key de Resend.
# RESEND_API_KEY=re_xxx
# Remitente verificado en Resend (ej: bookings@tu-dominio.com)
# RESEND_FROM_EMAIL=Spiral Bookings <bookings@tu-dominio.com>
# Email del dueño/estudio que recibirá notificaciones.
# STUDIO_NOTIFICATION_EMAIL=owner@tu-dominio.com
