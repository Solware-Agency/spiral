{
  "name": "proyecto_spiral",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite",
    "optimize:images": "node scripts/optimize-images.mjs",
    "optimize:client-logos": "node scripts/optimize-client-logos.mjs",
    "optimize:logos": "node scripts/optimize-logos.mjs",
    "build": "pnpm run optimize:images && pnpm run optimize:client-logos && pnpm run optimize:logos && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "googleapis": "^171.4.0",
    "luxon": "^3.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
